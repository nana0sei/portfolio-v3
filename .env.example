# Copy to .env and fill in values.

# Cloudinary. Cloud name is public (exposed to the client via VITE_ prefix for
# building art image delivery URLs). The non-prefixed copy is used server-side
# by /api/media. API key/secret are server-only — never prefix them with VITE_.
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Spotify (server-only). The refresh token is generated by visiting
# /api/spotify/login and copying the value off the callback page. Spotify
# refresh tokens now expire after ~6 months, so repeat that when the widget
# goes quiet.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token

# Must match a redirect URI registered in the Spotify dashboard *exactly*.
# Spotify rejects `localhost` — use the loopback IP for local dev:
#   http://127.0.0.1:3000/api/spotify/callback
#   https://your-domain.com/api/spotify/callback
SPOTIFY_REDIRECT_URL=http://127.0.0.1:3000/api/spotify/callback

# Your Spotify account id. The callback refuses to hand out a refresh token to
# any other account, so nobody else can hijack the widget. Leave it unset on the
# very first local run — the callback page will tell you what it is.
SPOTIFY_USER_ID=your_spotify_user_id
